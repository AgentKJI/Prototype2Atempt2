# ========================
# Unity Generated Files
# ========================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]em[Pp]rofile[Rr]/
.artifacts/
artifacts/

# ========================
# Unity Cache & Crash Files
# ========================
sysinfo.txt
*.stackdump
crashlytics-build.properties

# ========================
# NEVER ignore .meta files!
# Unity uses these to track GUIDs for all asset references.
# Deleting or ignoring them causes missing references in scenes.
# ========================
# *.meta   <-- DO NOT uncomment this line

# ========================
# Packages
# Keep manifest.json and packages-lock.json tracked so
# Unity restores the correct packages (e.g. Visual Scripting)
# on every machine after a pull.
# ========================
# Packages/   <-- DO NOT ignore this folder

# ========================
# Visual Studio / Rider IDE
# ========================
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
ExportedObj/
*.svd
*.pdb
*.opendb
*.VC.db

# ========================
# VS Code
# ========================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

# ========================
# NuGet / .NET
# ========================
*.nupkg
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# ========================
# Secrets & Environment
# ========================
*.env
*.pfx
*.publishsettings

# ========================
# OS Generated Files
# ========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ========================
# JetBrains Rider
# ========================
*.sln.iml

# ========================
